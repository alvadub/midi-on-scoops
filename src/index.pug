head
  style.
    :root {
      --bg: #1a1a2e;
      --surface: #16213e;
      --accent: #0f3460;
      --highlight: #e94560;
      --text: #eaeaea;
      --muted: #555;
      --font-mono: "JetBrains Mono", "Fira Code", monospace;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font-mono);
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    input, button, textarea, select {
      background-color: var(--surface);
      color: var(--text);
      border: 1px solid var(--muted);
      font-family: var(--font-mono);
    }

    button {
      padding: 0.5em 1em;
      cursor: pointer;
      border-radius: 4px;
      font-size: 14px;
    }

    button:hover {
      background-color: var(--accent);
    }

    button:active {
      background-color: var(--highlight);
    }

    input[type="range"] {
      width: 100px;
      cursor: pointer;
    }

    select {
      padding: 0.3em 0.5em;
      border-radius: 4px;
      cursor: pointer;
    }

    label {
      display: flex;
      align-items: center;
      gap: 0.5em;
      font-size: 13px;
    }

    #toolbar {
      background-color: var(--surface);
      padding: 0.75em 1em;
      display: flex;
      align-items: center;
      gap: 1.5em;
      border-bottom: 1px solid var(--muted);
    }

    #editor {
      flex: 1;
      padding: 1em;
      font-family: var(--font-mono);
      font-size: 14px;
      resize: none;
      border: none;
      outline: none;
      line-height: 1.6;
    }

    #statusbar {
      background-color: var(--surface);
      padding: 0.5em 1em;
      display: flex;
      align-items: center;
      gap: 1em;
      border-top: 1px solid var(--muted);
      font-size: 12px;
    }

    #beat-dots {
      display: flex;
      gap: 4px;
      align-items: center;
    }

    .beat-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background-color: var(--muted);
      transition: background-color 0.05s;
    }

    .beat-dot.active {
      background-color: var(--highlight);
    }

    #status-message {
      margin-left: auto;
      opacity: 0.7;
    }

body
  script(src='https://unpkg.com/webaudiofont@2.6.61/npm/dist/WebAudioFontPlayer.js' inline)
  import(from='index.js')
