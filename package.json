{
  "name": "midi-on-scoops",
  "version": "0.0.0",
  "type": "module",
  "description": "MIDI/DAW for the DUB enthusiast!",
  "author": "Alvaro Cabrera <pateketrueke@gmail.com> (https://soypache.co)",
  "_main": "dist/midi-on-scoops.cjs.js",
  "_module": "dist/midi-on-scoops.es.js",
  "bin": {
    "dub": "bin/dub",
    "dub-lint": "bin/dub-lint.js",
    "validate-midi": "bin/validate-midi.js",
    "midi2dub": "bin/midi2dub.js"
  },
  "license": "MIT",
  "scripts": {
    "dev": "npm run build -- -w",
    "dist": "npm run build -- -q",
    "check": "eslint 'src/**/*.{js,pug,svelte}'",
    "build": "mortero -dX'{lib,components}' -ecss.less -I.gitignore -p8081 -spublic",
    "test": "npm run test:unit --",
    "dub:lint": "node bin/dub-lint.js",
    "test:unit": "node japaFile.js",
    "test:coverage": "c8 --all --src src --reporter=text --reporter=html node japaFile.js",
    "test:coverage:unit": "npm run test:coverage --",
    "test:report": "c8 report"
  },
  "mortero": {
    "bundle": [
      "**/{main*,index}.js"
    ],
    "rename": [
      "src/**:{filepath/1}"
    ],
    "options": {
      "less": {
        "plugins": [
          "less-plugin-autoprefix"
        ]
      }
    }
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.25.12",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-svelte3": "^3.4.1",
    "harmonics": "^1.1.2",
    "japa": "^4.0.0",
    "less": "^4.5.1",
    "less-plugin-autoprefix": "^2.0.0",
    "midi-writer-js": "^3.2.1",
    "mortero": "^0.0.126",
    "pug": "^3.0.3",
    "scribbletune": "^5.5.4",
    "svelte": "^5.53.9"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "jsmidgen": "^0.1.8",
    "keypress": "^0.2.1",
    "node-watch": "^0.7.4",
    "wargs": "^0.10.0"
  }
}
